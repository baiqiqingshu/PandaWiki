# PandaWiki Docker Compose 环境变量
# 复制此文件为 .env 并修改

# 对外暴露的端口
WIKI_PORT=8005

# PostgreSQL 密码
POSTGRES_PASSWORD=panda-wiki-secret

# Redis 密码 (留空则不设密码)
REDIS_PASSWORD=

# NATS 密码
NATS_PASSWORD=

# MinIO 凭证
MINIO_ROOT_USER=s3panda-wiki
MINIO_ROOT_PASSWORD=panda-wiki-secret

# JWT 密钥
JWT_SECRET=panda-wiki-jwt-secret-change-me

# 管理员密码 (留空则使用默认)
ADMIN_PASSWORD=

# RAG Provider (noop=无RAG服务, ct=CT RAG)
RAG_PROVIDER=noop

# Wiki 站点自动初始化 (启动时自动创建，无需手动配置)
WIKI_NAME=PandaWiki
WIKI_SITE_PORT=8005

# 日志级别 (-4=debug, 0=info, 4=warn, 8=error)
LOG_LEVEL=0
